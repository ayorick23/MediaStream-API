{
  "info": {
    "name": "MediaStream API",
    "_postman_id": "mediastream-api-collection",
    "description": "Colección de endpoints para la API de MediaStream.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7027",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Account"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"firstName\": \"Juan\",\n  \"lastName\": \"Pérez\",\n  \"phone\": \"0991234567\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token || json.Token) {",
                  "  pm.collectionVariables.set('token', json.token ?? json.Token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Account/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Account", "login"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"Admin123!\",\n  \"rememberMe\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Categories"]
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Categories"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Comedia\",\n  \"description\": \"Películas y series de comedia\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "Upload Media",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Videos/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Videos", "upload"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "title", "type": "text", "value": "Mi video" },
                { "key": "categoryId", "type": "text", "value": "00000000-0000-0000-0000-000000000000" }
              ]
            }
          }
        },
        {
          "name": "Get Media by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Videos/media/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Videos", "media", ":id"],
              "variable": [
                { "key": "id", "value": "00000000-0000-0000-0000-000000000000" }
              ]
            }
          }
        },
        {
          "name": "Register View",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Videos/media/:id/view",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Videos", "media", ":id", "view"],
              "variable": [
                { "key": "id", "value": "00000000-0000-0000-0000-000000000000" }
              ]
            }
          }
        },
        {
          "name": "Stream Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Videos/stream/:nombreArchivo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Videos", "stream", ":nombreArchivo"],
              "variable": [
                { "key": "nombreArchivo", "value": "video.mp4" }
              ]
            }
          }
        }
      ]
    }
  ]
}
